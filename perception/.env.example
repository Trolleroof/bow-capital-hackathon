# Copy to .env and edit for your environment

# On laptop (dev):
YOLO_MODEL=yolo11n.pt
DEVICE=cpu
VIDEO_SOURCE=0           # webcam, or path to .mp4

# On Jetson (after export_trt.py):
# YOLO_MODEL=yolo11n.engine
# DEVICE=0
# REID_DEVICE=cpu        # keep ReID on CPU so YOLO has the full GPU budget
# YOLO_IMGSZ=416         # reduce from 640 if hitting CUDA OOM on Nano
# VIDEO_SOURCE=/path/to/euroc_clip.mp4

# Bus -- orchestrator control and image buses
WS_HOST=localhost
WS_PORT=8000
IMAGE_WS_PORT=8001

# ROS2 topic camera_node publishes to / rosmain subscribes from
ROS_CAMERA_TOPIC=/camera/image_raw

# Detection thresholds
YOLO_CONF=0.40
FACE_CONF=0.60

# FPV stream -- set to 1 to transmit grayscale (1 byte/pixel) instead of RGB (3 bytes/pixel)
# Detection pipeline is unaffected; only the broadcasted frames are converted.
GRAYSCALE_STREAM=0
